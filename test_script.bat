{"script":"@echo off\r\nchcp 65001 >nul 2>&1\r\nif defined OPTWIN_PERSIST goto :optwin_run\r\nset \"OPTWIN_PERSIST=1\"\r\ncmd /k \"%~f0\"\r\nexit /b\r\n:optwin_run\r\nset \"OPTWIN_BAT=%~f0\"\r\npowershell.exe -NoProfile -ExecutionPolicy Bypass -EncodedCommand \r\nexit /b\r\n:: === OPTWIN PS ===\r\ntrap {\n    Write-Host \"\" \n    Write-Host \"  ERROR: $_\" -ForegroundColor Red\n    Write-Host \"  Press any key to exit...\" -ForegroundColor Gray\n    $null = $Host.UI.RawUI.ReadKey(\"NoEcho,IncludeKeyDown\")\n    break\n}\n\n#\n#    OptWin -- Windows Optimization Script\n#    Version   : 1.3.0\n#    Date      : 16.03.2026 15:39:48\n#    Developer : ahmetly_\n#    Website   : https://optwin.tech\n#    GitHub    : https://github.com/ahmetlygh/optwin\n#    Open-source & free -- review every command\n#\n\n# ===== SELF-ELEVATION =====\n$isAdmin = ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)\n\nif (-not $isAdmin) {\n    Write-Host \"\"\n    Write-Host \"  [*] Requesting administrator privileges...\" -ForegroundColor Yellow\n    Write-Host \"\"\n    $elevated = $false\n    try {\n        Start-Process -FilePath $env:OPTWIN_BAT -Verb RunAs\n        $elevated = $true\n    } catch { }\n    if ($elevated) { exit }\n    Write-Host \"\"\n    Write-Host \"  ========================================\" -ForegroundColor Red\n    Write-Host \"  ERROR: Administrator privileges could not be obtained automatically.\" -ForegroundColor Red\n    Write-Host \"  ========================================\" -ForegroundColor Red\n    Write-Host \"\"\n    Write-Host \"  This script requires administrator privileges to run.\" -ForegroundColor Yellow\n    Write-Host \"  Please right-click the file and select 'Run as administrator'.\" -ForegroundColor Yellow\n    Write-Host \"\"\n    Write-Host \"  Press any key to exit...\" -ForegroundColor Gray\n    $null = $Host.UI.RawUI.ReadKey(\"NoEcho,IncludeKeyDown\")\n    exit\n}\n\n$host.UI.RawUI.WindowTitle = \"OptWin Optimizer Script\"\n\nClear-Host\nWrite-Host \"\"\nWrite-Host \"  ================================================================\" -ForegroundColor Magenta\nWrite-Host \"\" -ForegroundColor Magenta\nWrite-Host \"       OOOO  PPPP  TTTTT W   W  III  N   N\" -ForegroundColor Cyan\nWrite-Host \"      O    O P   P   T   W   W   I   NN  N\" -ForegroundColor Cyan\nWrite-Host \"      O    O PPPP    T   W W W   I   N N N\" -ForegroundColor Cyan\nWrite-Host \"      O    O P       T   WW WW   I   N  NN\" -ForegroundColor Cyan\nWrite-Host \"       OOOO  P       T    W W   III  N   N\" -ForegroundColor Cyan\nWrite-Host \"\" -ForegroundColor Magenta\nWrite-Host \"  ================================================================\" -ForegroundColor Magenta\nWrite-Host \"    Windows Optimization Tool\" -ForegroundColor White\nWrite-Host \"  ----------------------------------------------------------------\" -ForegroundColor DarkGray\nWrite-Host \"    Version   : 1.3.0\" -ForegroundColor Gray\nWrite-Host \"    Date      : 16.03.2026 15:39:48\" -ForegroundColor Gray\nWrite-Host \"  ----------------------------------------------------------------\" -ForegroundColor DarkGray\nWrite-Host \"    Open-source & free\" -ForegroundColor DarkGray\nWrite-Host \"    GitHub: github.com/ahmetlygh/optwin\" -ForegroundColor DarkGray\nWrite-Host \"  ================================================================\" -ForegroundColor Magenta\nWrite-Host \"\"\n\nWrite-Host \"  Cleaning temporary files...\" -ForegroundColor Cyan\nRemove-Item -Path \"$env:TEMP\\*\" -Recurse -Force -ErrorAction SilentlyContinue\nRemove-Item -Path \"$env:WINDIR\\Temp\\*\" -Recurse -Force -ErrorAction SilentlyContinue\nWrite-Host \"      Done\" -ForegroundColor Green\nWrite-Host \"\"\n\nWrite-Host \"\"\nWrite-Host \"  ========================================\" -ForegroundColor Green\nWrite-Host \"       Optimization Complete!\" -ForegroundColor Green\nWrite-Host \"       Please restart your PC.\" -ForegroundColor Green\nWrite-Host \"  ========================================\" -ForegroundColor Green\nWrite-Host \"\"\nWrite-Host \"  Thank you for using OptWin!\" -ForegroundColor Cyan\nWrite-Host \"  by ahmetly_ -- https://optwin.tech\" -ForegroundColor Gray\nWrite-Host \"\"\nWrite-Host \"  Press any key to exit...\" -ForegroundColor Gray\n$null = $Host.UI.RawUI.ReadKey(\"NoEcho,IncludeKeyDown\")\n"}