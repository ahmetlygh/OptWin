generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_users")
}

model Category {
  id           String                @id @default(cuid())
  slug         String                @unique
  icon         String?
  order        Int                   @default(0)
  enabled      Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  translations CategoryTranslation[]
  features     Feature[]

  @@map("categories")
}

model CategoryTranslation {
  id         String   @id @default(cuid())
  categoryId String
  lang       String
  name       String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, lang])
  @@map("category_translations")
}

model Feature {
  id           String               @id @default(cuid())
  slug         String               @unique
  categoryId   String
  icon         String
  iconType     String               @default("solid")
  risk         RiskLevel            @default(low)
  noRisk       Boolean              @default(false)
  order            Int                  @default(0)
  enabled          Boolean              @default(true)
  selectCount      Int                  @default(0)
  newBadge         Boolean              @default(false)
  newBadgeExpiry   DateTime?
  createdAt        DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  commands     FeatureCommand[]
  translations FeatureTranslation[]
  category     Category             @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("features")
}

model FeatureTranslation {
  id        String  @id @default(cuid())
  featureId String
  lang      String
  title     String
  desc      String
  feature   Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([featureId, lang])
  @@map("feature_translations")
}

model FeatureCommand {
  id            String  @id @default(cuid())
  featureId     String
  lang          String
  command       String
  scriptMessage String
  feature       Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([featureId, lang])
  @@map("feature_commands")
}

model DnsProvider {
  id        String  @id @default(cuid())
  slug      String  @unique
  name      String
  primary   String
  secondary String
  order     Int     @default(0)
  enabled   Boolean @default(true)

  @@map("dns_providers")
}

model Preset {
  id           String              @id @default(cuid())
  slug         String              @unique
  featureSlugs String[]
  enabled      Boolean             @default(true)
  order        Int                 @default(0)
  translations PresetTranslation[]

  @@map("presets")
}

model PresetTranslation {
  id       String @id @default(cuid())
  presetId String
  lang     String
  name     String
  preset   Preset @relation(fields: [presetId], references: [id], onDelete: Cascade)

  @@unique([presetId, lang])
  @@map("preset_translations")
}

model SiteStats {
  id             String   @id @default("main")
  totalVisits    Int      @default(0)
  totalScripts   Int      @default(0)
  totalDownloads Int      @default(0)
  updatedAt      DateTime @updatedAt

  @@map("site_stats")
}

model DailyStat {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  visits    Int      @default(0)
  scripts   Int      @default(0)
  downloads Int      @default(0)

  @@map("daily_stats")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model SiteSetting {
  key         String   @id
  value       String
  type        String   @default("string")
  description String?
  updatedAt   DateTime @updatedAt

  @@map("site_settings")
}

model UiTranslation {
  id    String @id @default(cuid())
  key   String
  lang  String
  value String

  @@unique([key, lang])
  @@map("ui_translations")
}

model ScriptLabel {
  id    String @id @default(cuid())
  lang  String
  key   String
  value String

  @@unique([lang, key])
  @@map("script_labels")
}

model VisitDedup {
  id     String   @id @default(cuid())
  ipHash String
  date   DateTime @db.Date

  @@unique([ipHash, date])
  @@map("visit_dedup")
}

model PageContent {
  id           String   @id @default(cuid())
  pageSlug     String   // "privacy" | "terms"
  lang         String
  disclaimer   String?  // Translation disclaimer text
  lastUpdated  String   // "March 2026" etc.
  sectionOrder Int      // 0, 1, 2...
  title        String   // Section title
  content      String   // JSON array of paragraphs: ["paragraph1", "paragraph2"]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([pageSlug, lang, sectionOrder])
  @@map("page_contents")
}

enum RiskLevel {
  low
  medium
  high
}
