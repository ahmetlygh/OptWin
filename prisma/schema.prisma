// OptWin v1.3 — Prisma Schema
// PostgreSQL — All site content is database-driven

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== AUTH =====

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_users")
}

// ===== FEATURES & CATEGORIES =====

enum RiskLevel {
  low
  medium
  high
}

model Category {
  id           String   @id @default(cuid())
  slug         String   @unique // e.g. "system", "network"
  icon         String?  // font-awesome class
  order        Int      @default(0)
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  translations CategoryTranslation[]
  features     Feature[]

  @@map("categories")
}

model CategoryTranslation {
  id         String @id @default(cuid())
  categoryId String
  lang       String // "en", "tr"
  name       String // e.g. "System Optimization"

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, lang])
  @@map("category_translations")
}

model Feature {
  id         String    @id @default(cuid())
  slug       String    @unique // e.g. "cleanTemp"
  categoryId String
  icon       String    // font-awesome class e.g. "fa-trash-can"
  iconType   String    @default("solid") // "solid" or "brands"
  risk       RiskLevel @default(low)
  noRisk     Boolean   @default(false) // if true, risk badge is hidden
  order      Int       @default(0)
  enabled    Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  category     Category              @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  translations FeatureTranslation[]
  commands     FeatureCommand[]

  @@map("features")
}

model FeatureTranslation {
  id        String @id @default(cuid())
  featureId String
  lang      String // "en", "tr"
  title     String
  desc      String

  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([featureId, lang])
  @@map("feature_translations")
}

model FeatureCommand {
  id            String @id @default(cuid())
  featureId     String
  lang          String // "en", "tr" — for script progress messages
  command       String // PowerShell command(s)
  scriptMessage String // e.g. "Cleaning temporary files..."

  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([featureId, lang])
  @@map("feature_commands")
}

// ===== DNS =====

model DnsProvider {
  id        String  @id @default(cuid())
  slug      String  @unique // e.g. "cloudflare"
  name      String  // Display name
  primary   String  // Primary IP
  secondary String  // Secondary IP
  order     Int     @default(0)
  enabled   Boolean @default(true)

  @@map("dns_providers")
}

// ===== PRESETS =====

model Preset {
  id          String   @id @default(cuid())
  slug        String   @unique // "recommended", "gamer"
  featureSlugs String[] // array of feature slugs
  enabled     Boolean  @default(true)
  order       Int      @default(0)

  translations PresetTranslation[]

  @@map("presets")
}

model PresetTranslation {
  id       String @id @default(cuid())
  presetId String
  lang     String
  name     String // e.g. "Recommended Settings"

  preset Preset @relation(fields: [presetId], references: [id], onDelete: Cascade)

  @@unique([presetId, lang])
  @@map("preset_translations")
}

// ===== STATS =====

model SiteStats {
  id           String   @id @default("main")
  totalVisits  Int      @default(0)
  totalScripts Int      @default(0)
  updatedAt    DateTime @updatedAt

  @@map("site_stats")
}

model DailyStat {
  id       String   @id @default(cuid())
  date     DateTime @db.Date
  visits   Int      @default(0)
  scripts  Int      @default(0)

  @@unique([date])
  @@map("daily_stats")
}

// ===== CONTACT MESSAGES =====

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

// ===== SITE SETTINGS — Admin-controlled key-value store =====

model SiteSetting {
  key         String   @id // e.g. "maintenance_mode", "site_version", "footer_year"
  value       String   // stored as string, parsed by type
  type        String   @default("string") // "string", "boolean", "number", "json"
  description String?
  updatedAt   DateTime @updatedAt

  @@map("site_settings")
}

// ===== UI TRANSLATIONS — All static strings admin-editable =====

model UiTranslation {
  id    String @id @default(cuid())
  key   String // e.g. "hero.title", "footer.text", "preset.recommended"
  lang  String
  value String

  @@unique([key, lang])
  @@map("ui_translations")
}
